PORT=3000
ALLOWED_ORIGIN=http://localhost:5173
CLERK_SECRET_KEY=sk_test_your_secret_key
# Optional but recommended for networkless JWT verification in production:
# CLERK_JWT_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# Optional comma-separated origin allowlist for Clerk tokens:
# CLERK_AUTHORIZED_PARTIES=http://localhost:5173,https://your-frontend-domain.com

# MongoDB
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=devrooms

# Pusher (server-side)
PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=your_cluster

# Gemini (server-side, for @mia)
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-1.5-flash

# Mia chat context (how many recent messages to include; max 8)
MIA_CONTEXT_MESSAGES=4
