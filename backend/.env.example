PORT=3000
ALLOWED_ORIGIN=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
# Optional fallback for networks that block SRV DNS lookups.
# Get this "standard connection string" from MongoDB Atlas Connect > Drivers.
# Example shape:
# MONGODB_URI_DIRECT=mongodb://your_username:your_password@host1:27017,host2:27017,host3:27017/?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority
MONGODB_DB=devrooms

# Pusher (server-side)
PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=your_cluster

# Gemini (server-side, for @mia)
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-1.5-flash

# Mia chat context (how many recent messages to include; max 8)
MIA_CONTEXT_MESSAGES=4
